# ClawRouter 配置示例
# 复制此文件到 ~/.openclaw/clawrouter.env 并修改

# ===========================================
# 基础配置
# ===========================================

# 钱包私钥（可选，默认自动生成）
# BLOCKRUN_WALLET_KEY=0x...

# 本地代理端口（默认 8402）
BLOCKRUN_PROXY_PORT=8402

# ===========================================
# 路由配置
# ===========================================

# 默认路由策略: auto / eco / premium / free
DEFAULT_ROUTING_STRATEGY=auto

# 禁用智能路由（默认 false）
# CLAWROUTER_DISABLED=false

# ===========================================
# Solana 配置
# ===========================================

# Solana RPC 端点
CLAWROUTER_SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# ===========================================
# 支付配置
# ===========================================

# 首选链: base / solana
PREFERRED_CHAIN=base

# 最大单笔支出 (USDC)
MAX_SPEND_PER_REQUEST=0.10

# ===========================================
# 调试配置
# ===========================================

# 启用调试日志
# DEBUG=false

# 医生诊断模式
# DOCTOR_AUTO_ANALYZE=true