{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Weekly Report Schema",
  "type": "object",
  "required": ["week_start", "week_end", "title", "daily_summaries"],
  "properties": {
    "week_start": {
      "type": "string",
      "format": "date",
      "description": "Week start date (YYYY-MM-DD)"
    },
    "week_end": {
      "type": "string",
      "format": "date",
      "description": "Week end date (YYYY-MM-DD)"
    },
    "title": {
      "type": "string",
      "description": "Report title"
    },
    "daily_summaries": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "date": {"type": "string", "format": "date"},
          "total_markets": {"type": "integer"},
          "top_opportunities": {"type": "integer"}
        }
      }
    },
    "trends": {
      "type": "object",
      "properties": {
        "emerging_categories": {"type": "array", "items": {"type": "string"}},
        "declining_categories": {"type": "array", "items": {"type": "string"}}
      }
    },
    "metadata": {
      "type": "object",
      "properties": {
        "generated_at": {"type": "string", "format": "date-time"}
      }
    }
  }
}